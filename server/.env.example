# Optional: log level (debug | info | warn | error). Default: info
# LOG_LEVEL=info

# Optional: base directory for log files. Default: logs
# Logs are stored under LOG_BASE_DIR/YYYY/MM/ (e.g. logs/2025/03/app.2025-03-03.log).
# Rotation is daily; folders older than 90 days are removed at startup.
# LOG_BASE_DIR=logs

# Optional: port to run the server on. Default: 3001
# PORT=3001

# Optional: client url. Default: http://localhost:5173
# CLIENT_URL=http://localhost:5173

# Optional: jwt secret. Default: 
# JWT_SECRET=

# Optional: scanner token. Default: 
# SCANNER_TOKEN=

